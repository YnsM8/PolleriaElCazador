# Backend
# Use a Supabase/PostgreSQL connection string when the warehouse is deployed.
# Example format:
# DATABASE_URL=postgresql+psycopg://postgres:password@db.project-ref.supabase.co:5432/postgres
DATABASE_URL=
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
# Use the deployed API URL in Vercel, for example:
# VITE_API_URL=https://your-api.example.com
VITE_API_URL=http://localhost:8000
# For Vercel Services in a single project:
# VITE_API_URL=/server
